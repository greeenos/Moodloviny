{
  "manifest_version": 3,
  "name": "Moodloviny",
  "version": "1.0.0",
  "description": "AI asistent pro řešení Moodle kvízů - OpenAI, Gemini, Claude, OpenRouter",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*",
    "https://openrouter.ai/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_icon": "icon.png",
    "default_popup": "./popup/index.html"
  },

  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "content_scripts": [
    {
      "matches": ["*://*/**/mod/quiz/attempt.php*", "*://*/mod/quiz/attempt.php*", "file:///*"],
      "js": ["Moodloviny.js"],
      "run_at": "document_end"
    }
  ]
}
